{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "KeyVault": {
    "Uri": "https://merchstory-kv.vault.azure.net/"
  },
  "Storage": {
    "ContainerName": "merchstory",
    "SasTtlMinutes": 15,
    "SasTtlMinutesByPrefix": {
      "prints/": 60
    }
  },
  "Google": {
    "ApiKey": ""
  },
  "AllowedOrigins": {
    "Web": ""
  },
  "Jwt": {
    "Key": "",
    "Issuer": "MerchStory",
    "Audience": "MerchStoryApp",
    "ExpiryMinutes": "15",
    "MobileRefreshTokenExpiryDays": "30",
    "WebRefreshTokenExpiryDays": "1"
  }
}
